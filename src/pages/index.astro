---
import BaseLayout from "../layouts/BaseLayout.astro";
import { resume } from "../content/resume-data";
import type { ResumeRole } from "../content/resume-data";

type EmployerGroup = {
  key: string;
  company: ResumeRole["company"];
  jobs: ResumeRole[];
};

function groupByEmployer(jobs: ResumeRole[]): EmployerGroup[] {
  const groups: EmployerGroup[] = [];
  for (const job of jobs) {
    const key = `${job.company.zh}__${job.company.en ?? ""}`;
    const last = groups[groups.length - 1];
    if (last && last.key === key) last.jobs.push(job);
    else groups.push({ key, company: job.company, jobs: [job] });
  }
  return groups;
}

/** 同一雇主多段任职时，用最早一段起点 — 最晚一段终点 作副标题 */
function employerSpanLabel(jobs: ResumeRole[]): string | null {
  if (jobs.length < 2) return null;
  const earliest = jobs[jobs.length - 1].period;
  const latest = jobs[0].period;
  const start = earliest.split(/\s*[-–—]\s*/)[0]?.trim();
  const end = latest.split(/\s*[-–—]\s*/).pop()?.trim();
  if (start && end) return `${start} – ${end}`;
  return null;
}

const experienceGroups = groupByEmployer(resume.experiences);

const card =
  "rounded-2xl border border-teal-200/35 bg-white/90 shadow-md shadow-teal-900/[0.04] backdrop-blur-xl dark:border-teal-900/35 dark:bg-neutral-900/85 dark:shadow-black/30";
---

<BaseLayout title={`${resume.basic.name} - Resume`} description="Personal resume">
  <div id="app" data-lang="zh" class="relative mx-auto max-w-6xl px-5 py-12 sm:px-6 sm:py-14">
    <!-- Background: cool neutral + subtle teal depth -->
    <div
      aria-hidden="true"
      class="pointer-events-none fixed inset-0 -z-10 bg-gradient-to-b from-[#f0fafa] via-teal-50/35 to-cyan-50/40 dark:from-neutral-950 dark:via-teal-950/25 dark:to-neutral-900"
    />
    <div
      aria-hidden="true"
      class="pointer-events-none fixed inset-0 -z-10 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(20,184,166,0.14),transparent)] dark:bg-[radial-gradient(ellipse_70%_40%_at_50%_-15%,rgba(45,212,191,0.08),transparent)]"
    />

    <nav
      class="sticky top-0 z-50 -mx-5 mb-10 border-b border-teal-200/40 bg-white/90 px-5 py-3 shadow-sm shadow-teal-900/[0.04] backdrop-blur-xl dark:border-teal-900/40 dark:bg-neutral-950/90 dark:shadow-black/20 sm:-mx-6 sm:px-6"
    >
      <div class="flex min-h-[3.25rem] flex-col gap-3 py-1 sm:flex-row sm:items-center sm:justify-between sm:gap-4 sm:py-0">
        <div class="shrink-0 bg-gradient-to-r from-teal-800 to-teal-600 bg-clip-text text-[0.8125rem] font-bold tracking-[0.14em] text-transparent dark:from-teal-200 dark:to-cyan-300 sm:text-sm">
          {resume.basic.name}
        </div>

        <div class="flex min-w-0 flex-1 items-center justify-end gap-2 sm:gap-3">
          <div
            class="no-scrollbar flex min-w-0 flex-1 items-center gap-5 overflow-x-auto pr-1 text-[15px] font-semibold sm:flex-none sm:justify-end sm:overflow-visible sm:pr-0 sm:text-base"
          >
            <a href="#summary" class="nav-link shrink-0">
              <span data-i18n="zh">优势</span>
              <span data-i18n="en">Summary</span>
            </a>
            <a href="#ai-learning" class="nav-link shrink-0">
              <span data-i18n="zh">AI 学习</span>
              <span data-i18n="en">AI</span>
            </a>
            <a href="#experience" class="nav-link shrink-0">
              <span data-i18n="zh">经历</span>
              <span data-i18n="en">Experience</span>
            </a>
            <a href="#projects" class="nav-link shrink-0">
              <span data-i18n="zh">项目</span>
              <span data-i18n="en">Projects</span>
            </a>
            <a href="#skills" class="nav-link shrink-0">
              <span data-i18n="zh">技能</span>
              <span data-i18n="en">Skills</span>
            </a>
            <a href="#education" class="nav-link shrink-0">
              <span data-i18n="zh">教育</span>
              <span data-i18n="en">Education</span>
            </a>
            <a href="#certificates" class="nav-link shrink-0">
              <span data-i18n="zh">证书</span>
              <span data-i18n="en">Certs</span>
            </a>
            <a href="#contact" class="nav-link shrink-0">
              <span data-i18n="zh">联系</span>
              <span data-i18n="en">Contact</span>
            </a>
          </div>

          <div class="flex shrink-0 items-center gap-2">
            <button
              type="button"
              data-lang-switch="zh"
              data-lang-btn
              class="lang-btn min-h-10 min-w-[2.75rem] rounded-lg border-2 border-transparent bg-white px-3.5 py-2 text-base font-semibold text-neutral-800 shadow-sm transition hover:bg-teal-50 dark:bg-neutral-900 dark:text-neutral-100 dark:hover:bg-teal-950/50"
            >
              ZH
            </button>
            <button
              type="button"
              data-lang-switch="en"
              data-lang-btn
              class="lang-btn min-h-10 min-w-[2.75rem] rounded-lg border-2 border-transparent bg-white px-3.5 py-2 text-base font-semibold text-neutral-800 shadow-sm transition hover:bg-teal-50 dark:bg-neutral-900 dark:text-neutral-100 dark:hover:bg-teal-950/50"
            >
              EN
            </button>
          </div>
        </div>
      </div>
    </nav>

    <header class="mb-12 pt-8">
      <div class="flex max-w-3xl flex-col gap-8 sm:flex-row sm:items-start">
        <img
          src="/avatar.png"
          alt={`${resume.basic.name} — portrait`}
          class="h-28 w-28 shrink-0 rounded-full object-cover shadow-lg shadow-teal-900/15 ring-2 ring-teal-600/20 dark:shadow-teal-900/40 dark:ring-teal-400/25"
          width="112"
          height="112"
        />

        <div class="min-w-0 flex-1 space-y-3">
          <p
            class="text-sm font-bold uppercase tracking-[0.2em] text-teal-800 dark:text-teal-300"
          >
            <span data-i18n="zh">制造业运营与精益转型负责人</span>
            <span data-i18n="en">Manufacturing Operations & Lean Transformation Leader</span>
          </p>
          <h1 class="text-4xl font-bold tracking-tight text-neutral-950 dark:text-white sm:text-5xl lg:text-6xl">
            {resume.basic.name}
          </h1>
          <div
            class="h-1 w-20 max-w-[40%] rounded-full bg-gradient-to-r from-teal-600 to-cyan-500 shadow-sm shadow-teal-600/30"
            aria-hidden="true"
          />
          <p class="text-lg leading-relaxed text-neutral-600 dark:text-neutral-300">
            <span data-i18n="zh">{resume.basic.location.zh}</span>
            <span data-i18n="en">{resume.basic.location.en}</span>
            {" • "}
            {resume.basic.phone}
            {" • "}
            <span class="break-all">{resume.basic.email}</span>
          </p>
        </div>
      </div>
    </header>

    <!-- Summary -->
    <section id="summary" class:list={["reveal mb-12 border-t-4 border-t-teal-600 p-6 sm:p-8", card]}>
      <h2 class="section-heading">
        <span data-i18n="zh">优势小结</span>
        <span data-i18n="en">Advantage Summary</span>
      </h2>
      <ul class="mt-6 list-disc space-y-3 pl-6 marker:text-teal-600 dark:marker:text-teal-400">
        {resume.summary.map((s) => (
          <li class="text-base leading-relaxed text-neutral-700 dark:text-neutral-200">
            <span data-i18n="zh">{s.zh}</span>
            <span data-i18n="en">{s.en || s.zh}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- AI learning & WeChat -->
    <section id="ai-learning" class:list={["reveal mb-12 overflow-hidden", card]}>
      <div class="border-b border-teal-100/80 bg-gradient-to-r from-teal-50/90 to-cyan-50/50 px-6 py-4 dark:border-teal-900/40 dark:from-teal-950/40 dark:to-neutral-900/80 sm:px-8">
        <h2 class="section-heading !mb-0 !text-base sm:!text-lg">
          <span data-i18n="zh">{resume.aiLearning.title.zh}</span>
          <span data-i18n="en">{resume.aiLearning.title.en}</span>
        </h2>
        <p class="mt-3 max-w-3xl text-base font-medium leading-relaxed text-teal-900/90 dark:text-teal-100/90">
          <span data-i18n="zh">{resume.aiLearning.tagline.zh}</span>
          <span data-i18n="en">{resume.aiLearning.tagline.en}</span>
        </p>
      </div>
      <div class="grid gap-8 p-6 sm:grid-cols-[minmax(0,220px)_1fr] sm:items-start sm:gap-10 sm:p-8">
        <div class="mx-auto w-full max-w-[220px] sm:mx-0">
          <div class="rounded-2xl border border-teal-200/60 bg-white p-3 shadow-md dark:border-teal-800/50 dark:bg-neutral-950">
            <img
              src={resume.aiLearning.wechat.qrSrc}
              alt="WeChat QR — 小潘学与说"
              class="w-full rounded-lg"
              width="220"
              height="220"
              loading="lazy"
            />
          </div>
          <p class="mt-3 text-center text-sm font-bold text-teal-800 dark:text-teal-200">
            <span data-i18n="zh">{resume.aiLearning.wechat.accountName.zh}</span>
            <span data-i18n="en">{resume.aiLearning.wechat.accountName.en}</span>
          </p>
          <p class="mt-2 text-center text-xs font-medium leading-snug text-neutral-600 dark:text-neutral-400">
            <span data-i18n="zh">{resume.aiLearning.wechat.searchHint.zh}</span>
            <span data-i18n="en">{resume.aiLearning.wechat.searchHint.en}</span>
          </p>
        </div>
        <div>
          <h3 class="text-xs font-bold uppercase tracking-widest text-teal-800 dark:text-teal-300">
            <span data-i18n="zh">能力要点</span>
            <span data-i18n="en">Highlights</span>
          </h3>
          <ul class="mt-4 space-y-4">
            {resume.aiLearning.points.map((pt) => (
              <li class="flex gap-3 border-l-[3px] border-teal-400 pl-4 text-base leading-relaxed text-neutral-700 dark:border-teal-500 dark:text-neutral-200">
                <span>
                  <span data-i18n="zh">{pt.zh}</span>
                  <span data-i18n="en">{pt.en}</span>
                </span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- Experience -->
    <section id="experience" class="reveal mb-12">
      <div class="mb-6 flex items-center justify-between gap-4">
        <h2 class="section-heading">
          <span data-i18n="zh">工作经历</span>
          <span data-i18n="en">Work Experience</span>
        </h2>
      </div>

      <div class="space-y-8">
        {experienceGroups.map((group) => {
          const spanLabel = employerSpanLabel(group.jobs);
          return (
            <div
              class:list={[
                "overflow-hidden rounded-2xl border border-teal-200/40 bg-white/90 shadow-md shadow-teal-900/[0.06] backdrop-blur-xl dark:border-teal-900/35 dark:bg-neutral-900/85",
              ]}
            >
              <div class="border-b border-teal-700/20 bg-gradient-to-r from-teal-800 via-teal-700 to-teal-800 px-5 py-4 sm:px-6 sm:py-5">
                <h3 class="text-lg font-bold tracking-tight text-white sm:text-xl">
                  <span data-i18n="zh">{group.company.zh}</span>
                  <span data-i18n="en">{group.company.en || group.company.zh}</span>
                </h3>
                {spanLabel ? (
                  <p class="mt-2 text-base font-semibold tabular-nums tracking-tight text-teal-100">
                    {spanLabel}
                  </p>
                ) : null}
                {group.jobs.length > 1 ? (
                  <p class="mt-2 text-sm font-semibold text-teal-200/90">
                    <span data-i18n="zh">{group.jobs.length} 段任职</span>
                    <span data-i18n="en">{group.jobs.length} roles</span>
                  </p>
                ) : null}
              </div>

              <div class="divide-y divide-teal-100/60 dark:divide-teal-900/30">
                {group.jobs.map((job) => (
                  <article class="bg-gradient-to-br from-white to-teal-50/20 px-5 py-6 dark:from-neutral-900/80 dark:to-teal-950/20 sm:px-6 sm:py-7">
                    <div class="border-l-[3px] border-teal-500 pl-5 dark:border-teal-400">
                      <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-start sm:justify-between">
                        <h4 class="text-lg font-bold leading-snug text-neutral-900 dark:text-neutral-50 sm:text-xl">
                          <span data-i18n="zh">{job.title.zh}</span>
                          <span data-i18n="en">{job.title.en || job.title.zh}</span>
                        </h4>
                        <span class="inline-flex w-fit shrink-0 rounded-xl border border-teal-200/80 bg-teal-50 px-3.5 py-2 text-base font-bold tabular-nums tracking-tight text-teal-900 shadow-sm dark:border-teal-700/50 dark:bg-teal-950/60 dark:text-teal-100">
                          {job.period}
                        </span>
                      </div>
                      <ul class="mt-4 list-disc space-y-3 pl-5 marker:text-teal-500 dark:marker:text-teal-400">
                        {job.points.zh.map((p, idx) => (
                          <li class="text-base leading-relaxed text-neutral-700 dark:text-neutral-200">
                            <span data-i18n="zh">{p}</span>
                            <span data-i18n="en">{job.points.en?.[idx] || p}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  </article>
                ))}
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Projects -->
    <section id="projects" class="reveal mb-14">
      <div class="mb-8 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <h2 class="section-heading">
          <span data-i18n="zh">代表项目</span>
          <span data-i18n="en">Signature Projects</span>
        </h2>
        <p class="max-w-md text-base font-medium leading-relaxed text-teal-900/85 dark:text-teal-200/90">
          <span data-i18n="zh"
            >精益产线、产能扩建与数字化 PMO 三条主线，附可验证结果与指标。</span
          >
          <span data-i18n="en"
            >Lean lines, capacity expansion, and digital PMO—each backed by measurable outcomes.</span
          >
        </p>
      </div>

      <div class="space-y-12">
        {resume.projects.map((proj, idx) => (
          <article
            class="project-card relative overflow-hidden rounded-[1.75rem] border border-teal-200/50 bg-gradient-to-br from-white via-teal-50/25 to-cyan-50/35 shadow-[0_20px_50px_-24px_rgba(15,118,110,0.25)] transition-shadow duration-300 hover:shadow-[0_28px_60px_-22px_rgba(15,118,110,0.32)] dark:border-teal-800/50 dark:from-neutral-950 dark:via-teal-950/20 dark:to-neutral-900 dark:shadow-[0_24px_60px_-20px_rgba(0,0,0,0.65)] dark:hover:shadow-[0_28px_64px_-18px_rgba(20,184,166,0.12)]"
          >
            <div
              class="pointer-events-none absolute inset-y-0 left-0 w-1.5 bg-gradient-to-b from-teal-700 via-cyan-600 to-teal-500 opacity-95 dark:from-teal-400 dark:via-cyan-400 dark:to-teal-500"
              aria-hidden="true"
            />
            <div class="relative px-6 py-8 pl-8 sm:px-10 sm:py-10 sm:pl-11">
              <div class="flex flex-col gap-4 sm:flex-row sm:flex-wrap sm:items-start sm:justify-between">
                <div class="flex flex-wrap items-center gap-2">
                  <span class="inline-flex items-center rounded-full bg-gradient-to-r from-teal-800 to-teal-600 px-3.5 py-1.5 text-xs font-bold uppercase tracking-wider text-white shadow-sm dark:from-teal-600 dark:to-cyan-600">
                    {proj.period}
                  </span>
                  <span class="text-xs font-bold uppercase tracking-wider text-teal-700 dark:text-teal-300">
                    <span data-i18n="zh">项目</span>
                    <span data-i18n="en">Case</span>{" "}
                    {String(idx + 1).padStart(2, "0")}
                  </span>
                </div>
                {proj.metrics && proj.metrics.length > 0 ? (
                  <div class="flex flex-wrap gap-2 sm:justify-end">
                    {proj.metrics.map((m) => (
                      <div class="rounded-xl border border-teal-200/90 bg-gradient-to-br from-teal-50 to-white px-3 py-2 text-center shadow-sm dark:border-teal-800/60 dark:from-teal-950/50 dark:to-neutral-900/80">
                        <div class="text-lg font-bold tabular-nums tracking-tight text-teal-900 dark:text-teal-100">
                          {m.value}
                        </div>
                        <div class="text-[0.65rem] font-bold uppercase tracking-wide text-teal-700/90 dark:text-teal-300/90">
                          <span data-i18n="zh">{m.label.zh}</span>
                          <span data-i18n="en">{m.label.en}</span>
                        </div>
                      </div>
                    ))}
                  </div>
                ) : null}
              </div>

              <h3 class="mt-5 text-2xl font-bold leading-snug tracking-tight text-neutral-900 dark:text-white sm:text-[1.65rem]">
                <span data-i18n="zh">{proj.title.zh}</span>
                <span data-i18n="en">{proj.title.en}</span>
              </h3>
              <p class="mt-2 text-base font-bold text-teal-900 dark:text-teal-200">
                <span data-i18n="zh">{proj.company.zh}</span>
                <span data-i18n="en">{proj.company.en}</span>
              </p>
              <p class="mt-1 text-sm font-bold text-cyan-800 dark:text-cyan-300">
                <span data-i18n="zh">{proj.role.zh}</span>
                <span data-i18n="en">{proj.role.en}</span>
              </p>
              <p class="mt-5 text-base leading-relaxed text-neutral-600 dark:text-neutral-300">
                <span data-i18n="zh">{proj.context.zh}</span>
                <span data-i18n="en">{proj.context.en}</span>
              </p>

              <div class="mt-8 grid gap-6 lg:grid-cols-2">
                <div class="rounded-2xl border border-teal-200/80 bg-teal-50/50 p-5 dark:border-teal-800/40 dark:bg-teal-950/30">
                  <h4 class="text-xs font-bold uppercase tracking-widest text-teal-900 dark:text-teal-200">
                    <span data-i18n="zh">痛点与挑战</span>
                    <span data-i18n="en">Challenges</span>
                  </h4>
                  <ul class="mt-4 space-y-3 text-sm font-medium leading-relaxed text-neutral-700 dark:text-neutral-200">
                    {proj.painPoints.map((pt) => (
                      <li class="flex gap-2">
                        <span
                          class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-teal-500 dark:bg-teal-400"
                          aria-hidden="true"
                        />
                        <span>
                          <span data-i18n="zh">{pt.zh}</span>
                          <span data-i18n="en">{pt.en}</span>
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>
                <div class="rounded-2xl border border-cyan-200/70 bg-cyan-50/40 p-5 dark:border-cyan-900/35 dark:bg-cyan-950/20">
                  <h4 class="text-xs font-bold uppercase tracking-widest text-cyan-900 dark:text-cyan-200">
                    <span data-i18n="zh">关键行动</span>
                    <span data-i18n="en">Key moves</span>
                  </h4>
                  <ul class="mt-4 space-y-3 text-sm font-medium leading-relaxed text-neutral-700 dark:text-neutral-200">
                    {proj.actions.map((ac) => (
                      <li class="flex gap-2">
                        <span
                          class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-cyan-500 dark:bg-cyan-400"
                          aria-hidden="true"
                        />
                        <span>
                          <span data-i18n="zh">{ac.zh}</span>
                          <span data-i18n="en">{ac.en}</span>
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>

              <div class="mt-6 rounded-2xl border border-teal-300/60 bg-gradient-to-br from-teal-50/90 via-white to-cyan-50/40 p-5 dark:border-teal-800/50 dark:from-teal-950/35 dark:via-neutral-950 dark:to-neutral-950">
                <h4 class="text-xs font-bold uppercase tracking-widest text-teal-900 dark:text-teal-200">
                  <span data-i18n="zh">可验证成果</span>
                  <span data-i18n="en">Outcomes</span>
                </h4>
                <ul class="mt-4 space-y-3">
                  {proj.outcomes.map((o) => (
                    <li
                      class="flex gap-3 text-sm font-medium leading-relaxed text-neutral-700 dark:text-neutral-200"
                    >
                      <span
                        class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-teal-600 to-cyan-600 text-xs font-bold text-white shadow-sm dark:from-teal-500 dark:to-cyan-500"
                        aria-hidden="true"
                      >
                        ✓
                      </span>
                      <span>
                        <span data-i18n="zh">{o.zh}</span>
                        <span data-i18n="en">{o.en}</span>
                      </span>
                    </li>
                  ))}
                </ul>
              </div>

              <div class="mt-6 flex flex-wrap gap-2">
                {proj.tags.map((tg) => (
                  <span class="rounded-full border border-teal-200/70 bg-white/90 px-3 py-1 text-xs font-bold text-teal-800 shadow-sm dark:border-teal-800/50 dark:bg-teal-950/40 dark:text-teal-200">
                    <span data-i18n="zh">{tg.zh}</span>
                    <span data-i18n="en">{tg.en}</span>
                  </span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- Skills -->
    <section id="skills" class:list={["reveal mb-12 border-t-4 border-t-cyan-500 p-6 sm:p-8", card]}>
      <h2 class:list={["section-heading mb-6"]}>
        <span data-i18n="zh">技能</span>
        <span data-i18n="en">Skills</span>
      </h2>
      <div class="flex flex-wrap gap-2">
        {resume.skills.map((sk) => (
          <span class="rounded-full border border-teal-200/70 bg-teal-50/90 px-3.5 py-1.5 text-sm font-bold text-teal-900 dark:border-teal-800/50 dark:bg-teal-950/50 dark:text-teal-100"
          >
            <span data-i18n="zh">{sk.zh}</span>
            <span data-i18n="en">{sk.en}</span>
          </span>
        ))}
      </div>
    </section>

    <!-- Education & Training -->
    <section id="education" class="reveal mb-12">
      <h2 class:list={["section-heading mb-6"]}>
        <span data-i18n="zh">教育背景与培训</span>
        <span data-i18n="en">Education & Training</span>
      </h2>

      <div class="space-y-5">
        {resume.education.map((ed) => (
          <article class:list={["p-6 sm:p-7", card]}>
            <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-start sm:justify-between">
              <h3 class="text-lg font-semibold text-neutral-900 dark:text-neutral-50 sm:text-xl">
                <span data-i18n="zh">{ed.institution.zh}</span>
                <span data-i18n="en">{ed.institution.en}</span>
              </h3>
              <span class="inline-flex w-fit shrink-0 rounded-xl border border-teal-200/80 bg-teal-50 px-3.5 py-2 text-base font-bold tabular-nums text-teal-900 dark:border-teal-700/50 dark:bg-teal-950/60 dark:text-teal-100">
                {ed.period}
              </span>
            </div>
            <p class="mt-3 text-base text-neutral-700 dark:text-neutral-200">
              <span data-i18n="zh">
                {ed.major?.zh} {ed.degree ? `• ${ed.degree.zh}` : ""}
              </span>
              <span data-i18n="en">
                {ed.major?.en} {ed.degree ? `• ${ed.degree.en}` : ""}
              </span>
            </p>
          </article>
        ))}

        <div class:list={["p-6 sm:p-7", card]}>
          <h3 class="text-lg font-semibold text-neutral-900 dark:text-neutral-50">
            <span data-i18n="zh">培训课程</span>
            <span data-i18n="en">Training</span>
          </h3>
          <div class="mt-5 space-y-4">
            {resume.trainings.map((t) => (
              <div
                class="flex flex-wrap items-start justify-between gap-3 border-t border-black/[0.05] pt-4 first:border-t-0 first:pt-0 dark:border-white/[0.06]"
              >
                <div class="min-w-[240px]">
                  <p class="text-base font-medium text-neutral-900 dark:text-neutral-100">
                    <span data-i18n="zh">{t.title.zh}</span>
                    <span data-i18n="en">{t.title.en}</span>
                  </p>
                  <p class="mt-1 text-sm text-neutral-600 dark:text-neutral-400">
                    <span data-i18n="zh">{t.institution.zh}</span>
                    <span data-i18n="en">{t.institution.en}</span>
                  </p>
                </div>
                <span class="inline-flex shrink-0 rounded-lg border border-teal-200/70 bg-teal-50 px-3 py-1.5 text-sm font-bold tabular-nums text-teal-900 dark:border-teal-700/50 dark:bg-teal-950/50 dark:text-teal-100">
                  {t.period}
                </span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Certificates -->
    <section id="certificates" class:list={["reveal mb-12 border-t-4 border-t-teal-500 p-6 sm:p-8", card]}>
      <h2 class:list={["section-heading mb-6"]}>
        <span data-i18n="zh">证书</span>
        <span data-i18n="en">Certificates</span>
      </h2>

      <div class="flex flex-wrap gap-2">
        {resume.certificates.map((c) => (
          <span class="rounded-full border border-teal-200/70 bg-gradient-to-r from-teal-50 to-cyan-50/80 px-3.5 py-1.5 text-sm font-bold text-teal-900 dark:border-teal-800/50 dark:from-teal-950/60 dark:to-cyan-950/40 dark:text-teal-100"
          >
            <span data-i18n="zh">{c.label.zh}</span>
            <span data-i18n="en">{c.label.en}</span>
            : {c.value}
          </span>
        ))}
      </div>
    </section>

    <!-- Contact -->
    <section id="contact" class:list={["reveal mb-12 border-t-4 border-t-teal-600 p-6 sm:p-8", card]}>
      <h2 class="section-heading">
        <span data-i18n="zh">联系我</span>
        <span data-i18n="en">Contact</span>
      </h2>

      <div class="mt-6 grid gap-6 md:grid-cols-2">
        <div class="text-base text-neutral-700 dark:text-neutral-200">
          <p class="font-medium">
            <span data-i18n="zh">基本信息</span>
            <span data-i18n="en">Basic info</span>
          </p>
          <p class="mt-2">
            <span data-i18n="zh">{resume.basic.location.zh}</span>
            <span data-i18n="en">{resume.basic.location.en}</span>
            {" • "}
            {resume.basic.phone}
          </p>
          {resume.basic.email ? (
            <p class="mt-1 break-all">{resume.basic.email}</p>
          ) : null}
        </div>

        <form
          data-contact-form
          data-contact-email={resume.basic.email || ""}
          class="rounded-2xl border border-black/[0.06] bg-neutral-50/80 p-5 dark:border-white/[0.08] dark:bg-neutral-950/50"
          action="#"
          method="post"
        >
          <label class="mb-2 block text-sm font-medium text-neutral-700 dark:text-neutral-200">
            <span data-i18n="zh">你的姓名</span>
            <span data-i18n="en">Your name</span>
          </label>
          <input
            name="name"
            type="text"
            required
            class="mb-3 w-full rounded-lg border border-black/[0.08] bg-white px-3 py-2.5 text-sm outline-none focus:border-neutral-400 dark:border-white/[0.1] dark:bg-neutral-900"
          />

          <label class="mb-2 block text-sm font-medium text-neutral-700 dark:text-neutral-200">
            <span data-i18n="zh">你的邮箱</span>
            <span data-i18n="en">Your email</span>
          </label>
          <input
            name="email"
            type="email"
            required
            class="mb-3 w-full rounded-lg border border-black/[0.08] bg-white px-3 py-2.5 text-sm outline-none focus:border-neutral-400 dark:border-white/[0.1] dark:bg-neutral-900"
          />

          <label class="mb-2 block text-sm font-medium text-neutral-700 dark:text-neutral-200">
            <span data-i18n="zh">留言内容</span>
            <span data-i18n="en">Message</span>
          </label>
          <textarea
            name="message"
            required
            rows="4"
            class="mb-4 w-full resize-none rounded-lg border border-black/[0.08] bg-white px-3 py-2.5 text-sm outline-none focus:border-neutral-400 dark:border-white/[0.1] dark:bg-neutral-900"
          ></textarea>

          <button
            type="submit"
            class="w-full rounded-lg bg-gradient-to-r from-teal-700 to-teal-600 px-3 py-3 text-base font-bold text-white shadow-md shadow-teal-700/25 transition hover:from-teal-800 hover:to-teal-700 dark:from-teal-600 dark:to-cyan-600 dark:hover:from-teal-500 dark:hover:to-cyan-500"
          >
            <span data-i18n="zh">提交</span>
            <span data-i18n="en">Send</span>
          </button>
        </form>
      </div>
    </section>
  </div>

  <script is:inline>
    const root = document.getElementById("app");
    const saved = localStorage.getItem("resume_lang");
    const initial = saved || "zh";
    root.dataset.lang = initial;
    document.documentElement.lang = initial === "en" ? "en" : "zh-CN";

    function syncLangButtons() {
      const lang = root.dataset.lang === "en" ? "en" : "zh";
      document.querySelectorAll("[data-lang-btn]").forEach((btn) => {
        const on = btn.getAttribute("data-lang-switch") === lang;
        btn.classList.toggle("lang-btn-active", on);
      });
    }

    function setLang(lang) {
      root.dataset.lang = lang;
      document.documentElement.lang = lang === "en" ? "en" : "zh-CN";
      localStorage.setItem("resume_lang", lang);
      syncLangButtons();
    }

    document.querySelectorAll("[data-lang-switch]").forEach((btn) => {
      btn.addEventListener("click", () => setLang(btn.dataset.langSwitch));
    });
    syncLangButtons();

    // 静态站“联系我”：不依赖第三方表单服务，提交后打开邮件客户端。
    const contactForm = document.querySelector("form[data-contact-form]");
    if (contactForm) {
      const contactEmail = contactForm.dataset.contactEmail || "";
      contactForm.addEventListener("submit", (e) => {
        e.preventDefault();
        if (!contactEmail) return;

        const formData = new FormData(contactForm);
        const name = String(formData.get("name") || "").trim();
        const email = String(formData.get("email") || "").trim();
        const message = String(formData.get("message") || "").trim();

        const lang = root.dataset.lang === "en" ? "en" : "zh";
        const subjectPrefix =
          lang === "en" ? "Resume contact" : "简历联系";
        const bodyPrefix =
          lang === "en"
            ? "Please find my message below."
            : "以下是我的留言内容。";

        const subject = encodeURIComponent(
          `${subjectPrefix}${name ? `: ${name}` : ""}`
        );
        const body = encodeURIComponent(
          `${bodyPrefix}\n\nName: ${name}\nEmail: ${email}\n\n${message}`
        );

        window.location.href = `mailto:${contactEmail}?subject=${subject}&body=${body}`;
      });
    }

    // Reveal on scroll (lightweight; Apple-like feel)
    const revealEls = Array.from(document.querySelectorAll(".reveal"));
    const reduceMotion = window.matchMedia?.(
      "(prefers-reduced-motion: reduce)"
    ).matches;
    if (reduceMotion || !("IntersectionObserver" in window)) {
      revealEls.forEach((el) => el.setAttribute("data-visible", "true"));
    } else {
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.setAttribute("data-visible", "true");
              io.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.15 }
      );
      revealEls.forEach((el) => io.observe(el));
    }
  </script>
</BaseLayout>

